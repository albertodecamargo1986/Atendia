# AtendIA License Server - Environment Variables

# Server
PORT=3100

# PostgreSQL
DATABASE_URL=postgresql://atendia:password@localhost:5432/atendia_licenses

# RSA Key Paths (for JWT signing/verification)
RSA_PRIVATE_KEY_PATH=./keys/private.pem
RSA_PUBLIC_KEY_PATH=./keys/public.pem

# JWT
JWT_EXPIRES_IN=24h

# Heartbeat
HEARTBEAT_INTERVAL_MS=14400000

# License Rules
OFFLINE_TOLERANCE_DAYS=7
TRANSFER_LIMIT_PER_YEAR=2
