  "description": "License activation, validation, heartbeat, and security reporting server for AtendIA Desktop",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "ts-node dist/index.js",
    "dev": "ts-node-dev --respawn src/index.ts",
    "generate-keys": "bash scripts/generate-keys.sh"
  },
  "dependencies": {
