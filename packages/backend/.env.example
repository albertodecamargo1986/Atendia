# AtendIA Backend — Variáveis de ambiente

# Ambiente
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Banco de dados
DATABASE_URL=postgresql://atend:atend@localhost:5432/atend_ia

# Redis
REDIS_URL=redis://localhost:6379

# JWT — GERAR COM: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Licenças — GERAR COM: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
LICENSE_JWT_SECRET=

# IA
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEFAULT_AI_MODEL=gpt-4o-mini

# ElevenLabs (TTS / voz clonada)
ELEVENLABS_API_KEY=

# Mercado Pago
MP_ACCESS_TOKEN=
MP_SANDBOX_TOKEN=
MP_SANDBOX=false
MP_WEBHOOK_SECRET=

# WhatsApp — GERAR COM: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_ENCRYPTION_KEY=

# E-mail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="AtendIA <noreply@atend-ia.com>"

# Arquivos
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# URLs
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:3000

# CORS — lista separada por vírgulas em produção
ALLOWED_ORIGINS=http://localhost:5173

# Download URLs (opcional — defaults to GitHub Releases)
DOWNLOAD_URL_WIN=
DOWNLOAD_URL_MAC=
DOWNLOAD_URL_LINUX=

# Versão do app (para rota /download/latest)
APP_VERSION=1.0.0
