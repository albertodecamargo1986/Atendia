{
  "name": "desktop",
  "version": "1.0.0",
  "description": "AtendIA Desktop — Atendimento inteligente com IA + WhatsApp",
  "author": "AtendIA",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -n electron,renderer -c blue,green \"npm run dev:electron\" \"npm run dev:renderer\"",
    "dev:electron": "tsc -p electron/tsconfig.json && electron .",
    "dev:renderer": "vite",
    "build:security": "tsc -p tsconfig.security.json",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build:renderer": "vite build --outDir dist-renderer",
    "build": "npm run build:security && npm run build:electron && npm run build:renderer",
    "build:win": "npm run build && electron-builder --win",
    "dist": "electron-builder --win portable"
  },
  "dependencies": {
    "atend-ia-shared": "*",
    "better-sqlite3": "^11.1.0",
    "electron-log": "^5.1.7",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.2.1",
    "lucide-react": "^0.395.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "31.7.7",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.4.5",
    "vite": "^5.3.3"
  }
}
