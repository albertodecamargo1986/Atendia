{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "../dist-electron",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "sourceMap": true,
    "declaration": false
  },
  "include": ["./**/*.ts"],
  "exclude": ["../node_modules", "../dist", "../src"]
}
