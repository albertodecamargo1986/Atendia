# AtendIA — Variaveis de ambiente para PRODUCAO
# Copie este arquivo para .env e preencha os valores reais

# Senha do banco de dados
DB_PASSWORD=mude-esta-senha-para-uma-senha-forte

# JWT — gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

# IA
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEFAULT_AI_MODEL=gpt-4o-mini

# WhatsApp
SESSION_ENCRYPTION_KEY=chave-de-32-bytes-para-criptografia

# URLs do frontend (para CORS)
FRONTEND_URL=http://seudominio.com
ALLOWED_ORIGINS=http://seudominio.com,https://seudominio.com

# E-mail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="AtendIA <noreply@atend-ia.com>"
