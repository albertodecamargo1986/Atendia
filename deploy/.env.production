# AtendIA — Variaveis de ambiente para PRODUCAO
# Copie este arquivo para .env e preencha os valores reais
# Gere secrets com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# Senha do banco de dados (gerar automaticamente no install.sh)
DB_PASSWORD=mude-esta-senha-para-uma-senha-forte

# Redis (senha opcional em producao)
REDIS_PASSWORD=mude-esta-senha-redis

# JWT — 64 caracteres hex cada
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# IA — pelo menos uma chave obrigatoria
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEFAULT_AI_MODEL=gpt-4o-mini

# WhatsApp
SESSION_ENCRYPTION_KEY=chave-de-32-bytes-para-criptografia
WHATSAPP_AUTH_DIR=./whatsapp-auth

# Mercado Pago (obrigatorio para checkout)
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
MP_SANDBOX=true

# URLs do frontend (para CORS)
FRONTEND_URL=http://localhost
ALLOWED_ORIGINS=http://localhost

# Upload
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=10485760

# E-mail (opcional, para boas-vindas e notificacoes)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="AtendIA <noreply@atend-ia.com>"

# Logging
LOG_LEVEL=info
NODE_ENV=production