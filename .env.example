# AtendIA — Variáveis de ambiente (copiar para .env e preencher)

# Ambiente
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Banco de dados
DATABASE_URL=postgresql://atend:atend@localhost:5432/atend_ia

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=dev-jwt-secret-mude-em-producao-abc123
JWT_REFRESH_SECRET=dev-refresh-secret-mude-em-producao-xyz789
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# IA
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEFAULT_AI_MODEL=gpt-4o-mini

# WhatsApp
SESSION_ENCRYPTION_KEY=chave-de-32-bytes-para-criptografia

# E-mail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="AtendIA <noreply@atend-ia.com>"

# Arquivos
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Pagamentos
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
MERCADOPAGO_ACCESS_TOKEN=

# Licenciamento
LICENSE_PRIVATE_KEY=
LICENSE_PUBLIC_KEY=

# URLs
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:3000
